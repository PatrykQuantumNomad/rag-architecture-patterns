# Tier 4 Docker build — exclude everything the runtime does not need.
# Keeping the image lean keeps `docker push` / pull times reasonable
# even though the MineRU model cache itself is multi-GB.

# Python ephemera
**/__pycache__
**/.pytest_cache
*.egg-info/
.venv/

# Per-tier persistence directories (NEVER bake stale state into the image)
chroma_db/
lightrag_storage/
rag_anything_storage/

# Build / runtime outputs
tier-4-multimodal/.cache/
tier-4-multimodal/output/
evaluation/results/

# Repo metadata + CI
.git/
.github/
.gitignore
.gitattributes

# Editor / OS detritus
node_modules/
.DS_Store
*.swp
*.swo

# Secrets — never committed but doubly excluded here so a stray .env in
# the working tree does not leak into the image.
.env
.env.*
!.env.example
