# RAG Architecture Patterns — environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# REQUIRED for Tier 1 (chat + embeddings) and Tier 3 (LightRAG entity-extraction + answer LLM + embeddings via the OpenRouter unified gateway).
# OpenRouter proxies OpenAI, Anthropic, Google, Meta, and others behind a single
# OpenAI-compatible API — Tier 1 uses `openai/text-embedding-3-small` for the
# vector index and a configurable chat model (default `google/gemini-2.5-flash`,
# override at the CLI with `--model`). Tier 3 uses the same defaults — the
# graph-extraction LLM is also configurable via `--model`. Pricing matches each
# underlying provider 1:1.
#   Obtain at: https://openrouter.ai/keys
#   Browse models at: https://openrouter.ai/models
#
# REQUIRED for Phase 127 smoke test (legacy direct-Gemini path via shared.llm).
# Future tiers may keep using Gemini directly OR migrate to OpenRouter per-tier.
#   Obtain at: https://aistudio.google.com/app/apikey
#
# OPTIONAL: OPENAI_API_KEY for direct-OpenAI use cases. Tier 1 routes through
# OpenRouter so this is no longer required for it; kept for tiers/scripts that
# want native OpenAI access (e.g., Tier 2 Managed File Search if implemented).
#   Obtain at: https://platform.openai.com/api-keys
#
# OPTIONAL: S2_API_KEY raises the Semantic Scholar rate limit during corpus
# curation (Phase 127 Plan 04).
#   Request at: https://www.semanticscholar.org/product/api#api-key

OPENROUTER_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
S2_API_KEY=
DEFAULT_CHAT_MODEL=google/gemini-2.5-flash
DEFAULT_EMBEDDING_MODEL=openai/text-embedding-3-small
DATASET_ROOT=dataset
