# RAG Architecture Patterns — environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# REQUIRED: GEMINI_API_KEY drives the default chat + embedding stack across all tiers.
#   Obtain at: https://aistudio.google.com/app/apikey
#
# REQUIRED for Tier 1 (embeddings: text-embedding-3-small), Tier 2 (Managed File Search), Tier 5 (Agentic).
#   Obtain at: https://platform.openai.com/api-keys
#
# OPTIONAL: S2_API_KEY raises the Semantic Scholar rate limit during corpus curation (Plan 04).
#   Request at: https://www.semanticscholar.org/product/api#api-key

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
S2_API_KEY=
DEFAULT_CHAT_MODEL=gemini-2.5-flash
DEFAULT_EMBEDDING_MODEL=gemini-embedding-001
DATASET_ROOT=dataset
